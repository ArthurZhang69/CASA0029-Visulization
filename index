                activeBrandColor,
                dimmedPointColor
              ]);
              map.setPaintProperty("pts-glow", "circle-opacity", [
                "case",
                ["==", ["get", "brand"], activeBrand],
                glowOpacityPoints,
                pointOpacityDimmed
              ]);
            }
            
            // Smooth show brand filter section
            brandFilterSection.style.display = 'block';
            setTimeout(() => {
              brandFilterSection.style.maxHeight = '600px';
              brandFilterSection.style.opacity = '1';
            }, 10);

            const chartPanelEl = document.getElementById('chartPanel');
            if (chartPanelEl) {
              setTimeout(() => {
                renderCityRankings();
                chartPanelEl.classList.add('active');
              }, 0);
            }
          }
        });
      });

      const defaultModeButton = document.querySelector(`.mode-btn[data-mode="${defaultMode}"]`);
      defaultModeButton?.click();

      // Brand filter functionality
      const brandButtons = document.querySelectorAll('.brand-btn');
      brandButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const brand = btn.dataset.brand;

          if (brandTransitionTimer) {
            clearTimeout(brandTransitionTimer);
            brandTransitionTimer = null;
          }

          const transitionMs = 200;

          // Set smooth transition durations
          map.setPaintProperty('pts-core', 'circle-opacity-transition', { duration: transitionMs });
          map.setPaintProperty('pts-core', 'circle-color-transition', { duration: transitionMs });
          map.setPaintProperty('pts-core', 'circle-radius-transition', { duration: transitionMs });
          
          // Update active state
          brandButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          
          // Get current opacity based on mode
          const currentOpacity = currentMode === 'hybrid' ? pointOpacityHybrid : pointOpacityDefault;
          
          // Start a short fade-down so the filter switch feels smooth
          map.setPaintProperty("pts-core", "circle-opacity", 0);

          const applyBrandFilter = () => {
            if (brand === 'all') {
              map.setFilter("pts-core", ["has", "brand"]);
              if (currentMode === 'heatmap') {
                map.setFilter("kde-heatmap", ["has", "brand"]);
              }
              map.setPaintProperty("pts-core", "circle-color", circleColorByBrand);
              map.setPaintProperty("pts-core", "circle-opacity", currentOpacity);
              map.setFilter("pts-glow", ["has", "brand"]);
              map.setPaintProperty("pts-glow", "circle-color", circleColorByBrand);
              map.setPaintProperty("pts-glow", "circle-opacity", glowOpacityPoints);
              currentFilter = null;
              return;
            }

            const filter = ["==", ["get", "brand"], brand];
            const activeBrandColor = brandColors[brand] || allBrandsColor;
            map.setFilter("pts-core", filter);
            if (currentMode === 'heatmap') {
              map.setFilter("kde-heatmap", filter);
            }
            map.setPaintProperty("pts-core", "circle-color", activeBrandColor);
            map.setPaintProperty("pts-core", "circle-opacity", currentOpacity);
            map.setFilter("pts-glow", filter);
            map.setPaintProperty("pts-glow", "circle-color", activeBrandColor);
            map.setPaintProperty("pts-glow", "circle-opacity", glowOpacityPoints);
            currentFilter = brand;
          };

          brandTransitionTimer = setTimeout(applyBrandFilter, Math.round(transitionMs * 0.6));

          // Update hex layer if in hybrid mode (with smooth transition)
          if (currentMode === 'hybrid') {
            // Set smooth transition for hex layer
            map.setPaintProperty('hex-heatmap', 'fill-opacity-transition', { duration: 500 });
            
            // Update hex data
            if (brand === 'all') {
              updateHexLayer(geojsonData, 'all');
            } else {
              const filtered = {
                type: 'FeatureCollection',
                features: geojsonData.features.filter(f => f.properties?.brand === brand)
              };
              updateHexLayer(filtered, `brand:${brand}`);
            }
          }
        });
      });

      // Add click interaction for points
      map.on('click', 'pts-core', (e) => {
        const coordinates = e.features[0].geometry.coordinates.slice();
        const properties = e.features[0].properties;
        
        let popupContent = '<div style="font-family: Outfit, sans-serif; padding: 10px 12px; background: rgba(10,14,20,0.95); color: #e8eaed; border: 1px solid rgba(0, 217, 255, 0.15); border-radius: 8px; box-shadow: 0 10px 24px rgba(0,0,0,0.4);">';
        const title = properties.name || 'Logistics Facility';
        const titleText = title ? title.charAt(0).toUpperCase() + title.slice(1) : 'Logistics Facility';
        const isDefaultTitle = !properties.name || properties.name === 'Logistics Facility';
        const titleColor = isDefaultTitle
          ? '#7b8490'
          : (brandColors[properties.brand] || allBrandsColor);
        popupContent += `<strong style="color: ${titleColor};">${titleText}</strong><br>`;
        const allowedFields = [
          { key: 'name', label: 'name' },
          { key: 'city', label: 'city' },
          { key: 'place', label: 'place' },
          { key: 'postcode', label: 'postcode' },
          { key: 'website', label: 'website' },
          { key: 'opening_hours', label: 'opening hours' },
          { key: 'opening hours', label: 'opening hours' }
        ];
        const seenLabels = new Set();
        allowedFields.forEach(({ key, label }) => {
          if (seenLabels.has(label)) return;
          const value = properties[key];
          if (value !== undefined && value !== null && value !== '') {
            popupContent += `<small style="color:#9aa4b2;">${label}: <span style="color:#e8eaed;">${value}</span></small><br>`;
            seenLabels.add(label);
          }
        });
        popupContent += '</div>';
        
        new mapboxgl.Popup()
          .setLngLat(coordinates)
          .setHTML(popupContent)
          .addTo(map);
      });

      // Change cursor on hover
      map.on('mouseenter', 'pts-core', () => {
        map.getCanvas().style.cursor = 'pointer';
      });

      map.on('mouseleave', 'pts-core', () => {
        map.getCanvas().style.cursor = '';
      });

      // Map zoom event
      map.on('zoom', () => {
        const zoom = map.getZoom();
        if (currentMode === 'heatmap' && zoom > 8 && map.getLayoutProperty('kde-heatmap', 'visibility') === 'visible') {
          map.setLayoutProperty('pts-core', 'visibility', 'none');
        }
      });
      
      // About panel functionality
      const aboutButton = document.getElementById('aboutButton');
      const aboutPanel = document.getElementById('aboutPanel');
      const closeAbout = document.getElementById('closeAbout');

      // Highlight About button on initial load
      if (aboutButton) {
        aboutButton.classList.add('is-highlight');
        setTimeout(() => {
          aboutButton.classList.remove('is-highlight');
        }, 4500);
      }
      
      aboutButton.addEventListener('click', () => {
        chartPanel.classList.remove('active');
        aboutPanel.classList.toggle('active');
      });
      
      closeAbout.addEventListener('click', () => {
        aboutPanel.classList.remove('active');
      });
      
      // Close about panel when clicking outside
      document.addEventListener('click', (e) => {
        if (!aboutPanel.contains(e.target) && !aboutButton.contains(e.target) &&
            !chartPanel.contains(e.target) && !chartButton.contains(e.target) &&
            !brandFilterSection.contains(e.target)) {
          aboutPanel.classList.remove('active');
          chartPanel.classList.remove('active');
        }
      });
      
      // Close panels with Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          if (aboutPanel.classList.contains('active')) {
            aboutPanel.classList.remove('active');
          }
          if (chartPanel.classList.contains('active')) {
            chartPanel.classList.remove('active');
          }
        }
      });
      
      // Chart button functionality
      const chartButton = document.getElementById('chartButton');
      const chartPanel = document.getElementById('chartPanel');
      const closeChart = document.getElementById('closeChart');
      const cityRankings = document.getElementById('cityRankings');
      
      // Calculate city statistics
      function calculateCityRankings() {
        const cityCounts = {};
        
        geojsonData.features.forEach(feature => {
          const city = feature.properties['addr:city'] || feature.properties.city || 'Unknown';
          if (city && city !== 'Unknown') {
            cityCounts[city] = (cityCounts[city] || 0) + 1;
          }
        });
        
        // Sort cities by count
        const sortedCities = Object.entries(cityCounts)
          .sort(([,a], [,b]) => b - a)
          .slice(0, 20); // Top 20 cities
        
        return sortedCities;
      }
      
      // Render city rankings
      function renderCityRankings() {
        const rankings = calculateCityRankings();
        const maxCount = rankings[0]?.[1] || 1;
        
        cityRankings.innerHTML = rankings.map(([city, count], index) => {
          const percentage = (count / maxCount) * 100;
          const rankClass = index === 0 ? 'gold' : index === 1 ? 'silver' : index === 2 ? 'bronze' : '';
          // Escape city name for safe use in onclick
          const safeCityName = city.replace(/'/g, "\\'");
          
          return `
            <div class="city-rank-item" style="animation-delay: ${index * 0.05}s">
              <div class="city-rank-header">
                <div class="rank-number ${rankClass}">${index + 1}</div>
                <div class="city-name" onclick="flyToCity('${safeCityName}')" title="Click to fly to ${city}">${city}</div>
                <div class="city-count">${count.toLocaleString()}</div>
              </div>
              <div class="city-bar-container">
                <div class="city-bar" style="width: ${percentage}%"></div>
              </div>
            </div>
          `;
        }).join('');
      }
      
      // Function to fly to a city on the map
      window.flyToCity = function(cityName) {
        playTakeoffSound();
        // Find all facilities in this city
        const cityFeatures = geojsonData.features.filter(feature => {
          const city = feature.properties['addr:city'] || feature.properties.city;
          return city === cityName;
        });
        
        if (cityFeatures.length === 0) {
          console.log('No features found for city:', cityName);
          return;
        }
        
        // Calculate bounds of all features in this city
        const coords = cityFeatures.map(f => f.geometry.coordinates);
        const lngs = coords.map(c => c[0]);
        const lats = coords.map(c => c[1]);
        
        const minLng = Math.min(...lngs);
        const maxLng = Math.max(...lngs);
        const minLat = Math.min(...lats);
        const maxLat = Math.max(...lats);
        
        // Calculate center
        const centerLng = (minLng + maxLng) / 2;
        const centerLat = (minLat + maxLat) / 2;
        
        // Calculate appropriate zoom level based on bounds
        const lngDiff = maxLng - minLng;
        const latDiff = maxLat - minLat;
        const maxDiff = Math.max(lngDiff, latDiff);
        
        // Determine zoom level (larger spread = lower zoom)
        let zoomLevel = 11;
        if (maxDiff > 0.5) zoomLevel = 9;
        else if (maxDiff > 0.2) zoomLevel = 10;
        else if (maxDiff > 0.1) zoomLevel = 11;
        else if (maxDiff > 0.05) zoomLevel = 12;
        else zoomLevel = 13;
        
        // Show notification
        showFlyNotification(cityName, cityFeatures.length);
        
        // Fly to the city with smooth animation
        map.flyTo({
          center: [centerLng, centerLat],
          zoom: zoomLevel,
          duration: 2000,
          essential: true,
          easing: function(t) {
            // Custom easing: ease-in-out
            return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
          }
        });
      };

      function playTakeoffSound() {
        try {
          const AudioContextClass = window.AudioContext || window.webkitAudioContext;
          if (!AudioContextClass) return;
          const audioCtx = new AudioContextClass();
          const duration = 0.9;
          const now = audioCtx.currentTime;

          const bufferSize = audioCtx.sampleRate * duration;
          const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
          const data = noiseBuffer.getChannelData(0);
          for (let i = 0; i < bufferSize; i += 1) {
            data[i] = (Math.random() * 2 - 1) * 0.5;
          }

          const noiseSource = audioCtx.createBufferSource();
          noiseSource.buffer = noiseBuffer;

          const bandpass = audioCtx.createBiquadFilter();
          bandpass.type = 'bandpass';
          bandpass.frequency.setValueAtTime(900, now);
          bandpass.frequency.exponentialRampToValueAtTime(2400, now + duration);
          bandpass.Q.value = 0.6;

          const gainNode = audioCtx.createGain();
          gainNode.gain.setValueAtTime(0.0001, now);
          gainNode.gain.exponentialRampToValueAtTime(0.06, now + 0.12);
          gainNode.gain.exponentialRampToValueAtTime(0.0001, now + duration);

          noiseSource.connect(bandpass);
          bandpass.connect(gainNode);
          gainNode.connect(audioCtx.destination);

          noiseSource.start(now);
          noiseSource.stop(now + duration);
          noiseSource.onended = () => {
            audioCtx.close();
          };
        } catch (e) {
          console.warn('Audio play failed:', e);
        }
      }
      
      // Function to show fly notification
      function showFlyNotification(cityName, facilityCount) {
        const notification = document.createElement('div');
        notification.style.cssText = `
          position: fixed;
          top: 120px;
          left: 50%;
          transform: translateX(-50%);
          background: linear-gradient(135deg, var(--color-success), var(--color-primary));
          color: var(--color-bg);
          padding: 14px 28px;
          border-radius: 12px;
          font-weight: 600;
          font-size: 14px;
          z-index: 1000;
          box-shadow: 0 8px 24px rgba(0, 217, 255, 0.4);
          animation: flyNoticeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
          pointer-events: none;
        `;
        notification.innerHTML = `
          <div style="display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 18px;">✈️</span>
            <span>Flying to <strong>${cityName}</strong> (${facilityCount} facilities)</span>
          </div>
        `;
        document.body.appendChild(notification);
        
        // Remove notification after animation
        setTimeout(() => {
          notification.style.animation = 'flyNoticeOut 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
          setTimeout(() => notification.remove(), 400);
        }, 2000);
      }
      
      chartButton.addEventListener('click', () => {
        const wasActive = chartPanel.classList.contains('active');
        
        // Close about panel if open
        aboutPanel.classList.remove('active');
        
        if (!wasActive) {
          renderCityRankings();
        }
        
        chartPanel.classList.toggle('active');
      });
      
      closeChart.addEventListener('click', () => {
        chartPanel.classList.remove('active');
      });
    });
  </script>
</body>
</html>
